{
  "appId": "com.traestartzlum.app",
  "appName": "Start Location",
  "webDir": "out",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://traestartzlum.vercel.app",
    "allowNavigation": [
      "traestartzlum.vercel.app",
      "*.supabase.co"
    ],
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "CapacitorUpdater": {
      "autoUpdate": true,
      "stats": true,
      "resetWhenUpdating": false
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "buildOptions": {
      "releaseType": "APK"
    }
  }
}
