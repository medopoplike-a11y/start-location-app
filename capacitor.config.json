{
  "appId": "com.sarte.location",
  "appName": "Start Location",
  "webDir": "out",
  "plugins": {
    "CapacitorUpdater": {
      "autoUpdate": true,
      "stats": true,
      "resetWhenUpdate": true
    }
  },
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "*.supabase.co",
      "*.vercel.app"
    ]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  }
}
