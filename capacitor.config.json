{
  "appId": "com.start.location",
  "appName": "Start Location",
  "webDir": "out",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://start-location-app.vercel.app",
    "androidScheme": "https",
    "hostname": "start-location-app.vercel.app",
    "cleartext": false,
    "allowNavigation": [
      "start-location-app.vercel.app",
      "sdpjvorettivpdviytqo.supabase.co",
      "*.supabase.co",
      "*.replit.dev",
      "*.replit.app"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "backgroundColor": "#020617",
    "buildOptions": {
      "releaseType": "APK"
    }
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "CapacitorUpdater": {
      "autoUpdate": false,
      "stats": false,
      "resetWhenUpdating": false
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "Keyboard": {
      "resize": "none",
      "style": "dark",
      "resizeOnFullScreen": false
    },
    "BackgroundGeolocation": {
      "staleLocationInterval": 10000,
      "distanceFilter": 2,
      "stopOnTerminate": false,
      "startOnBoot": true,
      "foregroundService": true,
      "enableHeadless": true,
      "heartbeatInterval": 60
    },
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchAutoHide": false,
      "backgroundColor": "#020617",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": true,
      "androidSpinnerStyle": "large",
      "iosSpinnerStyle": "small",
      "spinnerColor": "#3b82f6",
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}
