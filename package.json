{
  "name": "start-new",
  "version": "0.9.41",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "build": "next build",
    "export": "node scripts/static-export.mjs",
    "build:mobile": "npm run export && node fix-paths.js && node prepare-android.js && npx cap sync android",
    "build:android": "npm run build:mobile && node scripts/android-ensure-sdk.mjs && cd android && gradlew.bat assembleRelease",
    "build:ota": "node scripts/create-ota-bundle.js",
    "prepare-android": "node prepare-android.js",
    "start": "next start",
    "lint": "eslint . --max-warnings=400",
    "postinstall": "node fix-gradle-proguard.js",
    "deep-clean": "node scripts/deep-clean.mjs && npm install",
    "build:apk": "node scripts/generate-production-apk.mjs"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor-community/keep-awake": "^8.0.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/geolocation": "^8.0.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capacitor/toast": "^8.0.1",
    "@capgo/capacitor-navigation-bar": "^8.0.25",
    "@capgo/capacitor-updater": "^8.45.3",
    "@supabase/supabase-js": "^2.101.1",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/slim": "^3.9.1",
    "@types/leaflet": "^1.9.21",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.0.1",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-leaflet": "^5.0.0",
    "react-tsparticles": "^2.12.2",
    "tsparticles": "^3.9.1"
