# تكوين متغيرات البيئة - البيانات الحقيقية في .env.local فقط

## Web & Backend Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

## Server-only Keys (Never expose in browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

## Admin Configuration
NEXT_PUBLIC_ADMIN_EMAILS=admin1@example.com,admin2@example.com
ENCRYPTION_KEY=your-encryption-key-min-32-chars-here

## Mobile Configuration
NEXT_PUBLIC_APP_VERSION=0.2.1
NEXT_PUBLIC_BUILD_TYPE=production
VERCEL_URL=https://traestartzlum.vercel.app

## Firebase Configuration (إذا كنت تستخدمها)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project

## OTA Update Configuration
NEXT_PUBLIC_CAPGO_APP_ID=com.start.location
NEXT_PUBLIC_AUTO_UPDATE_ENABLED=true
NEXT_PUBLIC_UPDATE_CHECK_INTERVAL=1800000

## Development Only
DEBUG_MODE=false
VERBOSE_LOGGING=false

## PlayStore Configuration
PLAYSTORE_APP_ID=com.start.location
PLAYSTORE_TRACK=internal  # internal, alpha, beta, production
