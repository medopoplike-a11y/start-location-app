# تكوين متغيرات البيئة - البيانات الحقيقية في .env.local فقط

## Web & Backend Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

## Admin Configuration
NEXT_PUBLIC_ADMIN_EMAILS=admin1@example.com,admin2@example.com
ENCRYPTION_KEY=your-encryption-key-min-32-chars-here

## Mobile Configuration
NEXT_PUBLIC_APP_VERSION=0.2.1
NEXT_PUBLIC_BUILD_TYPE=production
VERCEL_URL=https://traestartzlum.vercel.app

## Firebase Configuration (إذا كنت تستخدمها)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project

## OTA Update Configuration
NEXT_PUBLIC_CAPGO_APP_ID=com.start.location
NEXT_PUBLIC_AUTO_UPDATE_ENABLED=true
NEXT_PUBLIC_UPDATE_CHECK_INTERVAL=1800000

## Android Signing (local release build)
RELEASE_STORE_FILE=../keystore.jks
RELEASE_STORE_PASSWORD=your-store-password
RELEASE_KEY_ALIAS=release-key
RELEASE_KEY_PASSWORD=your-key-password

## CI Android signing secret
# ضع هنا نص Keystore مشفراً بقاعدة 64 إذا كنت تريد بناء إصدار موقع في GitHub Actions
ANDROID_KEYSTORE_BASE64=your-base64-keystore-content

## Optional CI / OTA tokens
CAPGO_TOKEN=your-capgo-cli-token
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id

## Development Only
DEBUG_MODE=false
VERBOSE_LOGGING=false

## PlayStore Configuration
PLAYSTORE_APP_ID=com.start.location
PLAYSTORE_TRACK=internal  # internal, alpha, beta, production
